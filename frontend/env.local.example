# Copia este archivo a .env.local y ajusta los valores.
# cp .env.local.example .env.local

# ── Modo de datos ────────────────────────────────────────────────────────────
# false = backend real | true = mocks tipados (default si la var no existe)
NEXT_PUBLIC_USE_MOCKS=false

# ── URL del backend ──────────────────────────────────────────────────────────
# El proxy de next.config.ts reenvía /api/* a BACKEND_URL (server-side).
# NEXT_PUBLIC_API_URL queda vacío: las llamadas van a /api/... relativo.
NEXT_PUBLIC_API_URL=
BACKEND_URL=http://localhost:8000

# ── Auth ─────────────────────────────────────────────────────────────────────
# El backend acepta este token como Bearer. Un token = una empresa (multitenant).
NEXT_PUBLIC_API_KEY=demo-hg-key

# ── Módulos live ─────────────────────────────────────────────────────────────
# M5 (subsanación) y M6 (exposición) están vivos — mantener en true.
NEXT_PUBLIC_M5_M6_LIVE=true
