# Claude (primer intento extracción blanda). Sin esto, se usa el fallback Infermatic.
ANTHROPIC_API_KEY=sk-ant-...

# Fallback OpenAI-compatible: Infermatic / TotalGPT.
# Usado automáticamente cuando ANTHROPIC_API_KEY está vacío.
INFERMATIC_API_KEY=sk-...
INFERMATIC_BASE_URL=https://api.totalgpt.ai
INFERMATIC_MODEL=Qwen-Qwen3.6-35B-A3B

# OCR: ruta al binario Tesseract si no está en PATH (idioma 'spa' requerido)
TESSERACT_CMD=

# Multitenant: API keys de demo -> tenant. Formato: key:tenant_id,key2:tenant_id2
# En producción esto vive en una tabla; para el hackathon basta el .env.
API_KEYS=demo-hg-key:empresa-001,demo-hg-key-2:empresa-002

# Año de parámetros laborales (SMLMV, etc.)
PARAM_YEAR=2026

# --- J1: Telefonía de descargos (ElevenLabs Agents + Twilio, patrón AFFIRMA) ---
# Sin estas variables el backend funciona igual; solo se inhabilita la llamada real
# y el WhatsApp queda en modo "preview" (devuelve el mensaje que se enviaría).
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=                     # agente "Descargos HG" (créalo en el dashboard)
ELEVENLABS_AGENT_PHONE_NUMBER_ID=        # tras importar el número Twilio a ElevenLabs
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=                     # número saliente para la llamada, E.164 (+57...)
# WhatsApp de evidencia (Twilio Messaging). Por defecto el sandbox gratuito:
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
BACKEND_HOST=                            # host público (cloudflared) para webhook + media
HG_BACKEND_TOKEN=                        # secreto compartido del webhook submit_descargos
